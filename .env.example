# Copy to your host environment (do not commit secrets).

# Outbound integrations
NSM_SLACK_WEBHOOK_URL=
NSM_ALERT_WEBHOOK_URL=

# SMTP email
NSM_SMTP_HOST=
NSM_SMTP_PORT=587
NSM_SMTP_USERNAME=
NSM_SMTP_PASSWORD=
NSM_ALERT_EMAIL_FROM=nsm@localhost
NSM_ALERT_EMAIL_TO=

# SIEM forwarding
NSM_SIEM_OUTPUT_FILE=siem/alerts.jsonl
NSM_ALERTS_DATA_FILE=alerts.jsonl
NSM_ALERT_NOTIFY_MIN_SEVERITY=HIGH
NSM_PORT_SCAN_TRUSTED_SOURCES=

# SOC automation
NSM_SOC_AUTOMATION_ENABLED=true
NSM_SOC_AUTOMATION_MIN_SEVERITY=HIGH
NSM_SOC_AUTOMATION_COOLDOWN_SECONDS=300
NSM_SOC_AUTOMATION_LOG_FILE=soc_actions.log
NSM_INCIDENTS_LOG_FILE=incidents.db
NSM_SOC_AUTOMATION_AUTO_CONTAIN_CRITICAL=false
NSM_API_DEFAULT_ROLE=admin
NSM_DEVICE_INVENTORY_FILE=
NSM_UNAUTHORIZED_DEVICES_FILE=unauthorized_devices.jsonl

# Log rotation
NSM_ALERT_LOG_MAX_BYTES=5242880
NSM_ALERT_LOG_BACKUP_COUNT=5
